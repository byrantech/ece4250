logfile full_test.tcl
h Vdd!
l GND!
s

vector CLOCK phi0 phi1
clock CLOCK 00 10 00 01

l reset

s

vector clt_out clt_out7 clt_out6 clt_out5 clt_out4 clt_out3 clt_out2 clt_out1 clt_out0
vector lfsr_out lfsr_out7 lfsr_out6 lfsr_out5 lfsr_out4 lfsr_out3 lfsr_out2 lfsr_out1 lfsr_out0
vector log_out log_out7 log_out6 log_out5 log_out4 log_out3 log_out2 log_out1 log_out0
vector sqrt_out sqrt_out7 sqrt_out6 sqrt_out5 sqrt_out4 sqrt_out3 sqrt_out2 sqrt_out1 sqrt_out0
vector mux_out out7 out6 out5 out4 out3 out2 out1 out0
vector log_lfsr_out log_lfsr_out7 log_lfsr_out6 log_lfsr_out5 log_lfsr_out4 log_lfsr_out3 log_lfsr_out2 log_lfsr_out1 log_lfsr_out0
vector sqrt_latch_out sqrt_latch_out7 sqrt_latch_out6 sqrt_latch_out5 sqrt_latch_out4 sqrt_latch_out3 sqrt_latch_out2 sqrt_latch_out1 sqrt_latch_out0
vector result right_0 right_1 right_2 right_3 right_4 right_5 right_6 right_7
vector config left_5 left_4

| top_3 = lfsr_data_in
| top_4 = sqrt_data_in
| top_5 = log_data_in
| bottom_4 = clt_data_in_4
| bottom_3 = clt_data_in_3
| bottom_2 = clt_data_in_2
| bottom_1 = clt_data_in_1
| bottom_0 = clt_data_in_0
| left_3 = seed_en
| 00 = uniform = q0
| 01 = sqrt = q1
| 10 = clt = q2
| 11 = log = q3

ana phi0_in phi1_in

echo "Enabling seed generation"
h left_3

s

h top_3 top_4 top_5 bottom_4 bottom_3 bottom_2 bottom_1 bottom_0

c

l bottom_1 bottom_0

c

h bottom_1

c

l top_4

c

h bottom_0 top_4

c

l bottom_2 bottom_0 bottom_1

c

h bottom_2

c

h bottom_1 bottom_2

c


l left_3

echo "Completed seeding"

echo "=== START UNIFORM DISTRIBUTION ==="
setvector config 00

c
echo "uniform_sample_0"
d result
